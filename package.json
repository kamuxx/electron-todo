{
  "name": "electron-todo",
  "description": "App to manage ToDo Tasks",
  "version": "1.2.0",
  "author": "kamuxx",
  "license": "MIT",
  "main": "main.ts",
  "keywords": [
    "electron",
    "react",
    "typescript",
    "tailwindcss",
    "todo",
    "task-manager",
    "desktop-app",
    "vite"
  ],
  "homepage": "https://github.com/kamuxx/electron-todo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamuxx/electron-todo"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "build": {
    "appId": "com.github.kamuxx.electrontodo",
    "icon": "assets/logo.ico",
    "productName": "electron-todo",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "nsis": {
      "oneClick": false
    }
  },
  "private": true,
  "scripts": {
    "start:ui": "vite",
    "start:main": "electron .",
    "app:start": "concurrently \"bun run start:ui\" \"bun run start:main\"",
    "app:dir": "electron-builder --dir",
    "app:dist": "rm -rf release && electron-builder",
    "app:publish": "rm -rf release && electron-builder -p always"
  },
  "type": "module",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "publish": {
    "provider": "github",
    "owner": "kamuxx",
    "repo": "electron-todo"
  }
}